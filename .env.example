# Application
APP_NAME="Medical Voice Agent"
APP_VERSION="1.0.0"
ENVIRONMENT="development"
DEBUG=false

# API Configuration
API_HOST="0.0.0.0"
API_PORT="8000"
API_PREFIX="/api/v1"

# Groq API (REQUIRED - get key from https://console.groq.com)
GROQ_API_KEY="your_groq_api_key_here"
GROQ_TIMEOUT_SECONDS=30

# Database (SQLite for development, PostgreSQL for production)
# SQLite:
DATABASE_URL="sqlite:///./medical_agent.db"

# PostgreSQL:
# DATABASE_URL="postgresql://user:password@localhost:5432/medical_agent"

DATABASE_ECHO=false
DATABASE_POOL_SIZE=5

# Audio Processing
MAX_AUDIO_SIZE_MB=25
AUDIO_TEMP_DIR="/tmp/medical_agent_audio"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_PER_HOUR=100

# Logging
LOG_LEVEL="INFO"
LOG_FORMAT="json"

# Retention Policies
ASSESSMENT_RETENTION_DAYS=90
AUDIT_LOG_RETENTION_DAYS=365

# Feature Flags
ENABLE_SPECIALTY_ROUTING=true
ENABLE_AGENT_RESPONSES=true
ENABLE_METRICS_COLLECTION=true
ENABLE_AUDIT_LOGGING=true

# Security - CORS
CORS_ORIGINS='["http://localhost:3000", "http://localhost:8000"]'
CORS_ALLOW_CREDENTIALS=true

# Routing
ROUTING_CONFIDENCE_THRESHOLD=0.65
MIN_CONFIDENCE_TO_PROCEED=0.5

# Text-to-speech (optional - falls back to free gTTS if unset)
ELEVENLABS_API_KEY=""

# Real-time streaming pipeline
STREAM_CHUNK_SECONDS=2.5
STREAM_SILENCE_TIMEOUT_SECONDS=1.5

# LiveKit Cloud (cloud.livekit.io - free tier, no self-hosting/UDP ports needed)
LIVEKIT_URL="wss://your-project.livekit.cloud"
LIVEKIT_API_KEY="your-api-key"
LIVEKIT_API_SECRET="your-api-secret"
